(function(exports) {
  var Util = function() {

  }

  Util.prototype.dateFormat = function(time, format) {
    if(!time) return "--";
    var t = new Date(time);
    var tf = function(i) {
      return (i < 10 ? '0' : '') + i
    };
    return format.replace(/yyyy|MM|dd|HH|mm|ss/g, function(a) {
      switch (a) {
        case 'yyyy':
          return tf(t.getFullYear());
          break;
        case 'MM':
          return tf(t.getMonth() + 1);
          break;
        case 'mm':
          return tf(t.getMinutes());
          break;
        case 'dd':
          return tf(t.getDate());
          break;
        case 'HH':
          return tf(t.getHours());
          break;
        case 'ss':
          return tf(t.getSeconds());
          break;
      };
    });
  }
  /**
   * 对转转查询参数
   * @param  {[type]} param [description]
   * @param  {[type]} key   [description]
   * @return {[type]}       [description]
   */
  Util.prototype.urlEncode = function(param, key, encode) {
    var _this = this;
    if (param == null) return '';
    var paramStr = '';
    var t = typeof(param);
    if (t == 'string' || t == 'number' || t == 'boolean') {
      paramStr += '&' + key + '=' + ((encode == null || encode) ? encodeURIComponent(param) : param);
    } else {
      for (var i in param) {
        var k = key == null ? i : key + (param instanceof Array ? '[' + i + ']' : '.' + i);
        paramStr += _this.urlEncode(param[i], k, encode);
      }
    }
    return paramStr;

  };
  /**
   * 秒转时分秒字符串
   * @return {[type]} [description]
   */
  Util.prototype.hhmmss = function(time){
    var tf = function(i) {
      return (i < 10 ? '0' : '') + i
    };
    var time = parseInt(time);
    var h=parseInt(time/3600);
    var m=parseInt((time-h*3600)/60);
    var s = parseInt((time-h*3600)%60);
    var hours = tf(h);
    var minutes = tf(m);
    var seconds = tf(s);
    return hours+":"+minutes+":"+seconds;

  },
  /**
   * 转化时分秒=》课程播放页面
   * @param {*} time 
   * @returns 
   */
  Util.prototype.hhmmssOfVideo = function(time){
    var tf = function(i) {
      return (i < 10 ? '0' : '') + i
    };
    var time = parseInt(time);
    var h=parseInt(time/3600);
    var m=parseInt((time-h*3600)/60);
    var s = parseInt((time-h*3600)%60);
    var hours = tf(h);
    var minutes = tf(m);
    var seconds = tf(s);
    return h == 0 ? minutes+":"+seconds:hours+":"+minutes+":"+seconds;

  },
    /**
     * 时分秒转秒
     * @return {[type]} [description]
     */
    Util.prototype.parseSeconds = function(str){
      var arr = str.split(":");

      var h = parseInt(arr[0]);
      var m = parseInt(arr[1]);
      var s = parseInt(arr[2]);
      return h*3600+m*60+s;

    },

    Util.prototype.removeArrar = function (arr, item) {
      var result=[];
      for(var i=0; i<arr.length; i++){
        if(arr[i]!=item){
          result.push(arr[i]);
        }
      }
      return result;
    },
    Util.prototype.postDownload = function (options) {
      var config = $.extend(true,{method:'post'},options);
      var $iframe = $('<iframe id="down-file-iframe" />');
      var $form = $('<form method="'+config.method+'"/>');
      $form.attr('action',config.url);
      for(var key in config.data){
        $form.append('<input type="hidden" name="'+key+'" value="'+config.data[key]+'" />');
      }
      $iframe.append($form);
      $(document.body).append($iframe);
      $form[0].submit();
      $iframe.remove();
    }
    Util.prototype.formatDuring = function (result) {
      var h = Math.floor(result / 3600);
      if(h<10){h="0"+h;}
      var m = Math.floor((result / 60 % 60));
      if(m<10){m="0"+m;}
      var s = Math.floor((result % 60));
      if(s<10){s="0"+s;}
      return h+':'+m+':'+s;
    }
    /**
     * get sessionStorage value by key
     * @author bhp
     * @param key
     * @returns {null}
     */
    Util.prototype.getSession = function (key) {
        let data = sessionStorage[key];
        if (!data || data === "null") {
            return null;
        }
        return JSON.parse(data);
    }
    /**
     * set sessionStorage value by key
     * @author bhp
     * @param key
     * @param value
     */
    Util.prototype.setSession = function (key, value) {
        sessionStorage[key] = JSON.stringify(value);
    }
    /**
     * remove sessionStorage by key
     * @author bhp
     * @param key
     */
    Util.prototype.removeSession = function (key) {
        sessionStorage.removeItem(key);
    }
    Util.prototype.isEmptyObj = function(obj){
      for(var i in obj){
        if(i)return false
      }
    return true;
    }

    
    Util.prototype.getCookie = function (cookieName) {
      if (!cookieName || cookieName.length == 0) {
        return null;
      }
      if (document.cookie.length > 0) {
        c_start = document.cookie.indexOf(cookieName + "=");
        if (c_start != -1) {
          c_start = c_start + cookieName.length + 1;
          c_end = document.cookie.indexOf(";", c_start);
          if (c_end == -1) c_end = document.cookie.length;
          return unescape(document.cookie.substring(c_start, c_end));
        }
      }
      return null;
    };
  var util = new Util();
  exports.formatUtil = util;
})(window)
