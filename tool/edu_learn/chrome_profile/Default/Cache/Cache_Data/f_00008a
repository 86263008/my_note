  /**
   * 添加新评论到顶部
   * @param  {[type]} params [description]
   * @return {[type]}        [description]
   */
  Comments.prototype.addComments = function(params) {
    if (!params || !params.data || !(params.data instanceof Array)) {
      throw exception("参数不存在或格式不对!格式应为：{data:[]}")
    }
    this.nullData = this.nullData || $(_nullDataTemplate.wrapper);
    // 判断有无数据 没数据显示暂无内容框
    if (!params.data || params.data.length == 0) {
      this.$element.find('.comment-info').append(this.nullData);
      this.$element.find('.comment-info .loadmore').hide();
      return;
    } else {
      this.nullData.hide();
      if (params.data.length > 3) {
        this.$element.find('.comment-info .loadmore').show();
      } else {
        this.$element.find('.comment-info .loadmore').hide();
      }
    }
    var insertTo = params.to || "bottom";
    var loopLength = params.data.length < 3 ? params.data.length : 3;
    for (var i = 0; i < loopLength; i++) {
      var comment = params.data[i];
      // console.log(comment);
      var $comment = this.createComment(comment, i);
      var commentWrapper = this.$rootWrapper.find('.comment-text').first();
      if (insertTo == 'top') {// 加到顶部
        var first = commentWrapper.children('.default-comment-wrapper').first();
        if (first && first.length > 0) {
          console.log(first);
          $comment.insertBefore(first);
        } else {
          $comment.appendTo(commentWrapper);
        }
        this.data = this.data || [];
        // this.data.unshift(comment);
      } else {
        $comment.appendTo(commentWrapper);
        // this.data.push(comment);
      }

    }
  };


