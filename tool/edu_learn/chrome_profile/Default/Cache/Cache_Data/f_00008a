define('dialogExtend',[
  "jquery",
  "dialog"
], function($, dialog) {
  var defaultOptions = {
    type: 1,
    move: false,
    title: "新窗口",
    content: "&nbsp;"
  };
  var dialogplus = {



    /*
     * open 只有一个确认按钮
     * */
    alert: function(message,callback) {
      layer.alert(message, {
        move: false,
        title: '提示',
        closeBtn: 0,
        yes:function(index){
          
          if(callback){
            if(callback() !== false){
              layer.close(index);
            }
          }else{
            layer.close(index);
          }
        }
      });
    },
    loading: function(content) {
      return layer.load(2, {
        shade: false,
        content: content
      });
    },

    //成功弹出层
    success: function(message, callback) {
      var index = layer.open({
        move: false,
        content: message,
        icon: 1,
        yes: function() {
          if (callback && typeof callback == "function") {
            callback();
          }
          layer.close(index)

        },
      });
    },

    //失败
    error: function(message, callback) {
      var index = layer.open({
        move: false,
        content: message,
        icon: 2,
        yes: function() {
          if (callback && typeof callback == "function") {
            callback();
          }
          layer.close(index)

        },
      });
    },

    /*
     * 确认弹出层
     * */
    confirm: function(message, options, callback) {
      var type = typeof options === "function";
      var option = {
        title: "提示",
        btn: ['确定', '取消'] //按钮
      }
      if (type) {
        callback = options;
      } else {
        option = options;
      }
      var index = layer.confirm(message, option, function() {
        if (callback && typeof callback == "function") {
          callback();
        }
        layer.close(index)
      }, function() {
        layer.close(index)
      });

      var options = $.extend({}, option, options);
    },

    msg: function(message, time, callback) {
      var type = typeof time === "function";
      var timeOption = 2000;
      if (type) {
        callback = time;
      } else {
        timeOption = time;
      }
      var index = layer.msg(message || "", {
        time: timeOption
      }, function() {
        if (callback && typeof callback == "function") {
          callback();
        }
      });
    },
    open: function(options) {

      var options = $.extend({}, defaultOptions, options);
      // options.end = function(index,layero){
      //   console.log(index);
      //   console.log(this);
      //   if(layero.content instanceof jQuery){
      //     this.content.empty();
      //   }
      // }
      var index = layer.open(options);
      $(".layui-layer-page").css("height", "auto");
      return index;

    },
    load: function() {
      var index = layer.load(2, {
        shade: [0.1, '#fff'] //0.1透明度的白色背景
      });
      return index;
    },

    //tip点击提示
    tips: function(message) {
      var index = layer.tips(message || "", '.form-control-static', {
        tips: [1, '#3595CC'],
        time: 4000
      });
    },


    /*
     * confim中间内容传入html
     * */
