			});

			this.isFree = 0;

			this.questionPop = ""; // 练习题弹窗;

			// 苹果手机在播放视频时，当视频有练习题时，当用户打完练习题后，还会再提弹出该练习题
			// 此处记录下弹出时间的位置，已弹过的时间点，在关闭弹出2秒后不在弹出
			this.curAlertTime = 0;

			this.tjzjBizCode = "";
			this.tjzjType = 0; //tjzjType == 0不是天津职教 1=天津职教

			this.timeLimitClose = 0;  //限时学习   0 之前没有出来过  1 之前弹出过了，不需要再次弹出了
