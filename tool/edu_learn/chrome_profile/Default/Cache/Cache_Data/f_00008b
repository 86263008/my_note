	"js/common/SensorsDataUtils-c3bf11d9db.js"
], function ($, _, Backbone, dialog, AppEvent, QuestionView, restHtml, stopHtml, TipsHtml, PDFObject, SensorsDataUtils) {
	var view = Backbone.View.extend({
		el: ".video-wrapper",
