			if (progress != -1) {
				var id = vid;
				this.$(".catalog").find(".video-title[data-id='" + id + "']").attr('data-progress', progress);
				this.$(".catalog").find(".video-title[data-id='" + id + "']").attr('data-studyProgress', data.videoProgress);
				this.$(".catalog").find(".video-title[data-id='" + id + "']").children('.four').text(progressPercent + "%");
				this.playingVideo.studyProgress = data.videoProgress;
			}
		},
