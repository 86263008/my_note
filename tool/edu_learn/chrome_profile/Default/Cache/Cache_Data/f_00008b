				$(".video-title").each(function (e) {
					var id = $(this).attr("data-lessonId");
					if (window.p.lessonId == id) {
						$(".video-title").removeClass("on");
						$(this).addClass("on");
						$firstVideo = $(this);
					}
				})
			}

			this.playingVideo = {};
			var videoId = $firstVideo.attr("data-id");
			var lessonId = $firstVideo.attr("data-lessonId");
			var coursewareType = $firstVideo.data("type");
			this.isFree = $firstVideo.data("isfree");
			this.isClockDialog = 0;//标记位，0-还未弹出打卡弹窗1-已经弹出
			this.doPointTimeArr = [];
			this.isClicking = 0;//标记位，0-没有正在切换1-正在切换


			this.commonEventType = "pageload" //埋点事件类型，默认为 pageload-页面加载

			// //初始化查找所有课件/文档
			this._findAllVideos();
			if (coursewareType == 1) {
				var fileId = $firstVideo.attr("data-fileid");
				var state = $firstVideo.data("trans") ? $firstVideo.data("trans") : $firstVideo.data("state");
				// var state = $firstVideo.data("state");
				$firstVideo.parent().css("align-items", "flex-end");
				this.loadDocument(fileId, state);
				return;
			}
			if (videoId) {
				var idx = 0;//当前播放视频的索引
				this.getCoursePractise(videoId, function (practice) {
					_this.initPlayer(lessonId, idx, 0, practice);
				})

			}
		},

		events: {
			"click .video-title": "clickVideoHandler",
		},

		/**
		 * 查找所有视频课件
		 * @return {[type]} [description]
		*/
		_findAllVideos: function () {
			var videos = this.$(".video-title");
			this.videos = videos;
		},

		//组装清晰度数据
		packVideoQuality: function (videoObj) {
			var quiltys = [];
			var urlsArr = videoObj['urls'];
			if (urlsArr && urlsArr.length > 0) {
				if (videoObj.videoType == 1) {
					quiltys.push({ name: "流畅", url: urlsArr[0].url + "?token=" + videoObj.token });
				} else {
					_.each(urlsArr, function (item) {
						switch (item.quality) {
							case "FLUENT":
								quiltys.push({ name: "流畅", url: item.url + "?token=" + videoObj.token });
								break;
							case "SD":
								quiltys.push({ name: "标清", url: item.url + "?token=" + videoObj.token });
								break;
							case "HD":
								quiltys.push({ name: "高清", url: item.url + "?token=" + videoObj.token });
								break;
							case "FULL_HD":
								quiltys.push({ name: "超清", url: item.url + "?token=" + videoObj.token });
								break;
						}
					})
				}
				return quiltys;
			}
		},

		// 获取课程练习题
		getCoursePractise: function (videoId, cb) {
			var _this = this;
			var url = "/services/course/public/course/coursePraList?courseId=" + window.courseId + "&itemId=" + window.p.itemId + "&videoId=" + videoId;
			$.ajax({
				url: url,
				type: "get",
				dataType: "json",
				success: function (res) {
					if (res && res.success) {
						var data = res.data;
						if (!data || !data.length) {
							return cb && cb("")
						}
						cb && cb(data)
					}

				},
				error: function (xhr) {
					cb && cb("")
				}
			})
		},

		// 组装练习题弹出时间点
		packPractiseTimes: function (practice) {
			var _this = this;
			var practiseTimeArr = [];
			var videoPractise = practice || [];
			for (var i = 0, len = videoPractise.length; i < len; i++) {
				// selectedAnswerTxt  已做题的答案，字母
				// isCheck  当前试题选项是否选中
				// sortTxt   当前试题选项的字母序号
				// correctLetterTxt  当前试题的正确选项  字母
				// correctIdArr   当前试题的正确选线  ID
				// answerListObj  试题选项的对象形式
				// selectedAnswerIsCorrect  试题是否正确

				var item = this.packPractiseHandler(videoPractise[i])

				item.isAnswerQuestion = item.isAnswerQuestion || 0

				practiseTimeArr.push({
					time: item.alertTime,
					cb: function (cbObj) {
						_this.doPointTime.call(_this, cbObj);
					}
				});
			}
			this.playingPractices = videoPractise;
			if (!videoPractise || videoPractise.length == 0) return practiseTimeArr;

			return practiseTimeArr;
		},

		packPractiseHandler: function (itemQues) {
			if (itemQues.type == 0 || itemQues.type == 1 || itemQues.type == 2) {
				itemQues.correctLetterTxt = [];
				itemQues.correctIdArr = [];
				itemQues.selectedAnswerIsCorrect = false;
				itemQues.answerListObj = {};
				var selectedAnswerTxt = []
				var selectedAnswerArr = itemQues.selectedAnswer ? itemQues.selectedAnswer.split(',') : [];
				var selectedAnswerObj = {}
				for (var k = 0, kLen = selectedAnswerArr.length; k < kLen; k++) {
					selectedAnswerObj[selectedAnswerArr[k]] = selectedAnswerArr[k];
				}
				for (var j = 0, jLen = itemQues.answerList.length; j < jLen; j++) {
					var item = itemQues.answerList[j];
					itemQues.answerListObj[item.id] = item;
					item.isCheck = false;
					item.sortTxt = String.fromCharCode(item.sort + 64);
					if (item.isAnswer === '0') {
						itemQues.correctLetterTxt.push(item.sortTxt);
						itemQues.correctIdArr.push(item.id)
					}
					if (selectedAnswerObj[item.id]) {
						item.isCheck = true;
						selectedAnswerTxt.push(String.fromCharCode(item.sort + 64))
					}
				}
				itemQues.correctLetterTxt = itemQues.correctLetterTxt.join(',');
				itemQues.selectedAnswerTxt = selectedAnswerTxt.join(',');
				if (itemQues.selectedAnswerTxt === itemQues.correctLetterTxt) {
					itemQues.selectedAnswerIsCorrect = true;
				}
			} else if (itemQues.type == 4) {
				itemQues.correctLetterTxt = [];
				// selectedAnswerTxt  已做题的答案  字符串
				// selectedAnswerArr  已做题的答案  数组
				// answerTxt  试题项的已做答答案
				// isCorrect  试题项是否正确
				// selectedAnswerIsCorrect  试题是否正确
				// 填空题
				itemQues.inputCorrectIdArr = [];
				itemQues.inputCorrectArr = [];
				itemQues.selectedAnswerTxt = "";
				itemQues.selectedAnswerArr = [];
				itemQues.selectedAnswerIsCorrect = false;
				var selectedAnswerTxt = []
				var selectedAnswerObj = {}

				// 已做答的答案
				var selectedAnswer = [];
				if (itemQues.selectedAnswer) {
					selectedAnswer = JSON.parse(_.unescape(itemQues.selectedAnswer))
				}
				for (var k = 0, kLen = selectedAnswer.length; k < kLen; k++) {
					selectedAnswerObj[selectedAnswer[k].id] = selectedAnswer[k];
					selectedAnswerTxt.push(selectedAnswer[k].text);

				}

				if (selectedAnswerTxt && selectedAnswerTxt.length) {
					itemQues.selectedAnswerArr = selectedAnswerTxt;
					itemQues.selectedAnswerTxt = selectedAnswerTxt.join(',')
				}


				// inputCorrectArr  填空题答案数组
				for (var m = 0, mLen = itemQues.answerList.length; m < mLen; m++) {
					var item = itemQues.answerList[m];
					var name = _.unescape(item.name).replace(/<[^>]+>/g, '').replace(/&nbsp;/ig, '').replace(/\s/g, '')
					item.answerTxt = "";
					item.isCorrect = false;
					if (selectedAnswerObj[item.id]) {
						item.answerTxt = selectedAnswerObj[item.id].text;
						if (selectedAnswerObj[item.id].text == name) {
							item.isCorrect = true;
						}
					}
					itemQues.inputCorrectArr.push(name);
					itemQues.inputCorrectIdArr.push(item.id);
				}

				// disorder 答案有无顺序要求  1 无序  0 有序
				// 如果填空题已做答，判断这道题是否答对了
				if (selectedAnswer && selectedAnswer.length) {
					var selectedAnswerArr = itemQues.selectedAnswerTxt.split(',');
					var selectedAnswerIsCorrectArr = [];
					var isSort = itemQues.disorder;
					for (var j = 0, jLen = itemQues.inputCorrectArr.length; j < jLen; j++) {
						var item = itemQues.inputCorrectArr[j];
						if (isSort === 1) {
							// 无序
							var result = selectedAnswerArr.includes(item);
							if (result) {
								selectedAnswerArr.splice(selectedAnswerArr.indexOf(item), 1)
							}
							selectedAnswerIsCorrectArr.push(result);
						} else {
							// 有序
							var result = item == selectedAnswer[j].text;
							selectedAnswerIsCorrectArr.push(result);
						}
					}
					var valid = selectedAnswerIsCorrectArr.filter(function (item) {
						return !item
					})
					if (!valid || !valid.length) {
						itemQues.selectedAnswerIsCorrect = true;
					}
				}

			}
			return itemQues
		},

		// 生成视频进度条上的打点提示
		progressDotHandler: function () {
			if (!this.playingPractices || !this.playingPractices.length) {
				return []
			}
			var progressDot = [];
			var progressDotObj = {};
			for (var i = 0, len = this.playingPractices.length; i < len; i++) {
				if (progressDotObj[this.playingPractices[i].alertTime]) {
					continue
				}
				var tips = "<p class='progress-dot-info'>" + formatUtil.hhmmss(this.playingPractices[i].alertTime) + " 练习</p>";
				var item = {
					time: this.playingPractices[i].alertTime,
					text: tips
				}
				progressDot.push(item);
				progressDotObj[this.playingPractices[i].alertTime] = this.playingPractices[i];
			}
			return progressDot
		},

		//打点视频，节点回调方法
		doPointTime: function (cbObj) {
			if (this.curAlertTime) return;
			if (Number(this.playingVideo.studyProgress) + 2 * 60 > Number(cbObj.time) / 2) {
				this._doOpenPractices(cbObj);
			}

		},

		// 判断是否全屏播放
		isFullscreen: function () {
			return document.fullscreenElement ||
				document.msFullscreenElement ||
				document.mozFullScreenElement ||
				document.webkitFullscreenElement || false;
		},

		// 弹出练习题
		_doOpenPractices: function (cbObj) {
			var _this = this;
			if (this.playingPractices.length == 0) {
				return;
			}

			var theTimePracticies = _.filter(this.playingPractices, function (item) {
				var alertTime = item.alertTime;
				if (!alertTime || !item.videoId) return false;
				if (parseInt(alertTime) == cbObj.time && item.videoId == this.playingVideo.videoId) {
					return true;
				}
				return false;
			}, this);
			if (theTimePracticies.length == 0) return false;
			// 试题数量
			var number = {
				total: 0, // 总数量
				current: 0, // 当前
			}
			if (theTimePracticies.length > 1) {
				number.total = theTimePracticies.length;
			}

			//如果全屏播放，强制退出全屏
			var isFullscreen = this.isFullscreen();
			if (isFullscreen) {
				this.xgplayer.exitFullscreen()
			}
			if (this.xgplayer) {
				this.xgplayer.pause();
			}

			// 弹出试题弹窗，并作答
			var sortOpenDialog = function () {
				var _this = this;
				var practice = theTimePracticies.shift();
				this.curAlertTime = practice.alertTime;
				if (number.total) {
					number.current = number.total - theTimePracticies.length
				}
				var questionView = new QuestionView({
					model: practice,  // 试题
					number: number,  // 试题数量
					answersNumber: window.timilistParam.answersNumber || 0,  // 是否重复作答   0 不重复  1 可重复
					parentView: _this, // 父视图
					xgplayer: _this.xgplayer,  // 播放器
				});

				$("#modal").html(questionView.render().el);
				layer.closeAll()

				var area = ['700px', '500px'];
				if (window.screen.width < 700) {
					area = ['90%', '80%']
				}

				_this.questionPop = dialog.open({
					content: $("#modal"),
					title: "",
					closeBtn: 0,
					area: area,
				});
				this.listenToOnce(questionView, 'ans-yes', function (userAnswer) {
					_this.updateUserAnswer(practice, userAnswer)
					dialog.close(_this.questionPop);
					_this.questionPop = "";
					if (theTimePracticies.length == 0) {
						if (this.xgplayer) {
							this.xgplayer.play();
							setTimeout(function () {
								_this.curAlertTime = 0;
							}, 2000)
						}
						return;
					}
					sortOpenDialog.call(this);
				});
			}

			sortOpenDialog.call(this);
			return true;
		},

		updateUserAnswer: function (practice, userAnswer) {
			if (practice.isAnswerQuestion != 1 && userAnswer) {
				practice.isAnswerQuestion = 1;
				practice.selectedAnswer = userAnswer;
				this.packPractiseHandler(practice)
			}
		},

		//切换视频
		clickVideoHandler: function (e) {
			var _this = this;

			this.commonEventType = "videoclick"; //埋点-事件类型 videoclick-课件点击
			var target = $(e.currentTarget);
			if (this.isClicking == 1) {
				return;
			}
			var coursewareType = target.data("type");
			var lessonId = target.attr("data-lessonId");
			// 禁止观看指定课件
			if (lessonId == "877393689513025549" || lessonId == "877311133348364301" || lessonId == "877393596456153116" || lessonId == "877310409684963356" || lessonId == "811076432474628109" || lessonId == "811072911994822669" || lessonId == "608559250802491398" || lessonId == "726696930082488333" || lessonId == "726674720251535382") {
				dialog.msg("课件更新中，暂时无法播放，更新时间敬请关注。更新期间不影响已学学时。");
				return false;
			}
			var id = target.attr("data-id");

			//课件点击切换时发送埋点事件(视频走播放时埋点，pdf文件点击埋点)
			if (coursewareType == 1) {
				let sensorsParams = this.getSensorsParams("videoclick", "start", id);
				SensorsDataUtils.trackSensors(sensorsParams);
			}

			// 处理需要跳转外联的需求
			var jumpUrl = ''
			var courseLinkData = window.app_servers.courseLinkServer;// 获取需要外联跳转的课件数据

			for (var i = 0; i < courseLinkData.length; i++) {
				if (lessonId == courseLinkData[i].id) {
					jumpUrl = courseLinkData[i].linkTxt;
				}
			}

			if (jumpUrl) {
				var linkDialog = dialog.open({
					title: "提示",
					content: "<div class='loginOut-tip'>您即将离开本网站</div>",
					area: ["480px", "260px"],
					btn: ['确定'],
					yes: function () {
						dialog.close(linkDialog);
						window.open(jumpUrl);
					}
				});
			} else {
				this.doPointTimeArr = [];
				//音频文件增加参数 ：videoType = 0 视频 1= 音频
				if (target.hasClass('on')) {
					return;
				}
				this.isClicking = 1;
				// if(vid){
				this.$(".video-title.on").removeClass('on');
				target.addClass('on');
				if (coursewareType == 1) {
					var fileId = target.attr("data-fileId");
					var state = target.data("state");
					//如果全屏播放，强制退出全屏
					var isFullscreen = this.isFullscreen();
					if (isFullscreen) {
						this.xgplayer.exitFullscreen()
					}

					// this.$("#video").css('align-items','flex-end');
					this.loadDocument(fileId, state);
					return;
				} else {
					this.$("#video").css('align-items', 'center');
				}
				var idx = 0;
				this.videos.each(function (index, el) {
					var theId = $(this).attr("data-id");
					if (id == theId) {
						idx = index;
					}
				});
				this.getCoursePractise(id, function (practice) {
					_this.initPlayer(lessonId, idx, 1, practice);
				})
			}

		},

		// 埋点-获取参数
		getSensorsParams: function (eventType, eventAction, lessonId) {
			let sensorsParams = {
				event_type: eventType,            //事件类型
				event_action: eventAction,        //事件动作，
				project_id: window.p.projectId,   //项目id,
				seg_id: window.p.segId,           //阶段ID
				item_id: window.p.itemId,         //考核项ID
				course_id: window.courseId,       //课程id,
				course_type: "video",             //课程类型：video-点播课 open_video-开放课
				video_id: lessonId ? lessonId : this.playingVideo.videoId,   //视频id,
				// video_id:this.playingVideo.videoId,   //视频id,
				// video_play_time:parseInt(this.xgplayer.currentTime),//当前视频播放到的时间 
				create_time: new Date().getTime(),// 触发时间 
			};
			//答题或者打卡时添加 action_item_id
			if (eventType == 'answer' || eventType == 'signin') {
				sensorsParams.action_item_id = this.actionItemId;  //触发事件失误id(例如：打卡、答题)
			}
			return sensorsParams;
		},

		//init 视频播放器  //音频文件增加参数 ：videoType = 0 视频 1= 音频videoPlaySource-0-初始化播放1-切换播放
		initPlayer: function (lessonId, idx, videoPlaySource, practice) {
			var _this = this;
			var videoObj = _.findWhere(window.initlessons, { id: lessonId });
			if (videoObj) {
				if (videoObj.transState != '2') {
					//如果全屏播放，强制退出全屏
					var isFullscreen = this.isFullscreen();
					if (isFullscreen) {
						this.xgplayer.exitFullscreen();
					}
					//转码中，强制销毁视频
					if (this.xgplayer) {
						this.xgplayer.forceDestroy();
					}
					setTimeout(function () {
						_this.xgplayer = null;
						_this.$("#video-Player").html("<div style='width:100%;margin-top:40%;text-align:center;font-size:15px;color:#f99933'>视频正在转码中...</div>");
						_this.isClicking = 0;
						return false;
					}, 200);
				}
				var qualitys = this.packVideoQuality(videoObj);
				this.playingVideo = videoObj;
				//练习题
				var practiseTimeArr = this.packPractiseTimes(practice);
				// 视频进度条打点
				var progressDotArr = this.progressDotHandler();
				//视频打卡
				var doClckInTimeArr = this._doClockIn();
				//将联系题打点数组添加到打点数组
				this.doPointTimeArr = this.doPointTimeArr.concat(practiseTimeArr).concat(doClckInTimeArr);
				this.playingVideo['idx'] = idx;
				var studyProgress = formatUtil.hhmmssOfVideo(this.playingVideo.studyProgress);
				var volume = this.xgplayer ? this.xgplayer.volume : 0.5;
				var defineVideoUrl = videoObj['urls'] ? videoObj['urls'][0].url + "?token=" + videoObj.token : "";
				var videos_count = this.videos.length;
				//最后一个视频切换
				if (idx + 1 == videos_count) {
					var ignorArr = ["keyboard"];
				} else {
					var ignorArr = ["keyboard", "replay"];
				}
				//视频开始播放时间
				var lastPlayTime = this.playingVideo.progress < 1 ? this.playingVideo.studyProgress : 0;
				var options = {
					id: "video-Player",
					url: defineVideoUrl,
					// width: "100%",
					// height: "100%",
					fluid: true,
					volume: volume,
					autoplay: true,
					// 设置播放器视频起播时间
					lastPlayTime: lastPlayTime, //视频起播时间（单位：秒）
					lastPlayTimeHideDelay: 15, // 提示文字展示时长（单位：秒）
					definitionActive: 'click',
					closeVideoClick: false,
					playbackRate: [0.75, 1, 1.25, 1.5, 2],
					defaultPlaybackRate: 1,
					//allowSeekPlayed: window.timilistParam.isFastForward == 1 && this.playingVideo.progress <  1?true:false,
					videoBackground: {
						isCustom: this.playingVideo.videoType == 1 ? true : false,
						// background: 'url("<%=ctx%>/images/img-110-2bf69218a3.jpg"); center center/20% no-repeat, #000'
					},
					poster: videoObj['urls'] ? videoObj['urls'][0].imageUrl : "",
					lastPlayTimeTips: "已学习到<span class='xgplayer-lasttime'>" + studyProgress + "</span>",
					ignores: ignorArr,
					//计时功能
					countTime: {
						interval: 60,
						cb: function (cbObj) {
							_this.countTimeBack(cbObj) // 形参state，播放结束值为 end
						}
					},
					//视频打点功能
					dotList: this.doPointTimeArr,
					onTimeUpdate: function () {
					},
					progressDot: progressDotArr   // 进度条特殊点标记
				};

				// isFastForward  0 可以快进  1 首次学习不允许快进
				// progress  1 已学完
				if (window.timilistParam.isFastForward == 1 && this.playingVideo.progress != 1) {
					var dragMaxTime = 0;
					if (this.playingVideo.studyProgress && (this.playingVideo.studyProgress < this.playingVideo.duration)) {
						dragMaxTime = this.playingVideo.studyProgress;
					} else {
						dragMaxTime = 1;
					}
					options.dragMaxTime = dragMaxTime;
				}

				// 有练习题，且在考核里配置了“未完成课中练习，已学时长不计入学时”，则播放视频时弹窗提示
				if (window.timilistParam.questionConfig === 0 && this.playingPractices && this.playingPractices.length) {
					options.autoplay = false;
				}

				// 如果这个视频有未答的试题，且视频播放进度大于弹题的时间点，则视频从此试题弹出点前4秒开发播放
				if (this.playingPractices && this.playingPractices.length) {
					for (var k = 0, kLen = this.playingPractices.length; k < kLen; k++) {
						if (this.playingPractices[k].isAnswerQuestion != 1 && this.playingVideo.studyProgress > Number(this.playingPractices[k].alertTime)) {
							options.lastPlayTime = this.playingPractices[k].alertTime - 4;
							break;
						}
					}
				}

				// this.$("#video-Player").css("overflow", "hidden");

				// 切换视频时，如果有试题弹窗打开着，则关闭该弹窗；
				if (_this.questionPop) {
					dialog.close(_this.questionPop);
					_this.questionPop = "";
				}

				var tipsTxt = "";
				if (window.timilistParam.questionConfig === 0 && _this.playingPractices && _this.playingPractices.length) {
					tipsTxt = "本视频学习含有测试练习，请学习视频并完成测试后，才可获得相应学时。";
					// 是否答完所有的试题  true 已完成  false 没有完成
					var isComplete = true;
					for (var n = 0, nLen = practice.length; n < nLen; n++) {
						if (practice[n].isAnswerQuestion != 1) {
							isComplete = false;
							break
						}
					}
					if (this.playingVideo.studyProgress > 0 && !isComplete) {
						tipsTxt = "本视频学习含有测试练习，请学习视频并完成测试后，才可获得相应学时。<span class='question-no-complete-tips'>本视频您还未答题。</span>";
					}
				}

				if (videoPlaySource == 0 || !this.xgplayer) {
					this.$("#video-Player").html("");
					this.xgplayer = grtPlayer(options);
					this.isClicking = 0;
					if (qualitys && qualitys.length > 1) {
						this.xgplayer.emit('resourceReady', qualitys);
					}
					this.registEventPlayer();

					if (window.timilistParam.questionConfig === 0 && _this.playingPractices && _this.playingPractices.length) {
						dialog.alert(tipsTxt)
					}
				} else {
					if (this.xgplayer && this.xgplayer.switchVideo) {

						this.xgplayer.switchVideo(options, function (player) {
							_this.xgplayer = player;
							_this.isClicking = 0;
							// _this.$("#video-Player").css("float", "left");
							if (qualitys && qualitys.length > 1) {
								_this.xgplayer.emit('resourceReady', qualitys);
							}
							_this.registEventPlayer();
							if (window.timilistParam.questionConfig === 0 && _this.playingPractices && _this.playingPractices.length) {
								dialog.alert(tipsTxt)
							}
						});
					}
				}
			}
		},
		//注册播放器事件
		registEventPlayer: function () {
			var _this = this;

			// 埋点
			this.commonEventType = "videoclick"; //事件类型 ：videoclick-播放
